{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*":           ["./src/*"],
      "@rft/shared":   ["../../../packages/shared/src"],
      "@rft/shared/*": ["../../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "drizzle/**/*"],
  "exclude": ["**/*.test.ts", "node_modules", "dist"]
}
